<div class="space-y-8">
  <section>
    <label class="mb-2 block text-[11px] font-bold tracking-wider text-gray-500 uppercase sm:text-xs">
      Link público
    </label>

    <div class="rounded-2xl">
      <div class="flex items-center gap-2">
        <div class="relative flex-1">
          <input
            type="text"
            readonly
            value="<%= store_root_url(subdomain: @store.slug) %>"
            class="
              w-full truncate rounded-xl border border-gray-200 bg-white py-3 pr-3 pl-3 text-sm font-medium
              text-gray-700 shadow-sm transition-shadow focus:ring-2 focus:ring-blue-500/20 focus:outline-none
            "
          >
        </div>

        <%= render Clipboard::Component.new(
            text: store_root_url(subdomain: @store.slug),
            icon_only: true,
            variant: :ghost,
            size: :lg,
          ) %>
      </div>
    </div>
  </section>

  <section class="flex flex-col gap-3">
    <div>
      <h2 class="mb-2 block text-[11px] font-bold tracking-wider text-gray-500 uppercase sm:text-xs">
        Tienda
      </h2>
    </div>

    <div>
      <%= link_to store_root_url(subdomain: @store.slug), target: "_blank", class: "flex flex-col w-full items-center justify-center gap-2 sm:gap-3 p-3 sm:p-4 rounded-2xl border-2 border-gray-500 bg-white hover:bg-gray-50 hover:border-gray-300 hover:shadow-md transition-all group active:scale-95" do %>
        <div
          class="
            rounded-xl bg-accent/15 p-2 text-accent transition-all duration-300 group-hover:scale-110
            group-hover:bg-accent/25 sm:p-2.5
          "
        >
          <%= render_svg("store.svg", styles: "w-4 h-4") %>
        </div>

        <span class="text-[13px] font-semibold text-gray-700 sm:text-sm">Ver Tienda</span>
      <% end %>
    </div>
  </section>

  <section>
    <div class="mb-4 flex items-center gap-3">
      <div class="h-px flex-1 bg-gray-200"></div>

      <span class="text-[10px] font-semibold tracking-wider text-gray-400 uppercase sm:text-xs">
        Compartir en redes
      </span>

      <div class="h-px flex-1 bg-gray-200"></div>
    </div>

    <div class="grid grid-cols-3 gap-2 sm:gap-3">
      <%= link_to "https://www.facebook.com/", target: "_blank", class: "flex flex-col items-center gap-2 p-2 sm:p-3 rounded-2xl hover:bg-gray-50 border border-transparent hover:border-gray-100 transition-all group active:scale-95" do %>
        <div
          class="
            flex h-10 w-10 items-center justify-center rounded-full bg-[#1877F2]/10 transition-all duration-300
            sm:h-12 sm:w-12
          "
        >
          <%= render_svg("facebook.svg", styles: "w-5 h-5 text-[#1877F2] transition-colors") %>
        </div>

        <span class="text-[11px] font-semibold text-gray-600 sm:text-xs">Facebook</span>
      <% end %>

      <%= link_to "https://www.instagram.com/", target: "_blank", class: "flex flex-col items-center gap-2 p-2 sm:p-3 rounded-2xl hover:bg-gray-50 border border-transparent hover:border-gray-100 transition-all group active:scale-95" do %>
        <div
          class="
            flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-tr from-[#FFDC80] via-[#FD1D1D]
            to-[#833AB4] p-[2px] opacity-90 transition-all duration-300 sm:h-12 sm:w-12
          "
        >
          <div class="flex h-full w-full items-center justify-center rounded-full bg-white transition-colors duration-300">
            <%= render_svg("instagram.svg", styles: "w-5 h-5 text-[#E4405F] transition-colors") %>
          </div>
        </div>

        <span class="text-[11px] font-semibold text-gray-600 sm:text-xs">Instagram</span>
      <% end %>

      <%= link_to "https://web.whatsapp.com/", target: "_blank", class: "flex flex-col items-center gap-2 p-2 sm:p-3 rounded-2xl hover:bg-gray-50 border border-transparent hover:border-gray-100 transition-all group active:scale-95" do %>
        <div
          class="
            flex h-10 w-10 items-center justify-center rounded-full bg-[#25D366]/10 transition-all duration-300
            sm:h-12 sm:w-12
          "
        >
          <%= render_svg("whatsapp.svg", styles: "w-5 h-5 text-[#25D366] group-hover:text-white transition-colors") %>
        </div>

        <span class="text-[11px] font-semibold text-gray-600 sm:text-xs">WhatsApp</span>
      <% end %>
    </div>
  </section>
</div>
