<div class="group flex flex-col">
  <div class="relative w-full overflow-hidden bg-gray-200 shadow-sm transition-shadow group-hover:shadow-md"
       style="aspect-ratio: var(--sp-aspect); border-radius: var(--sp-radius);">
    <% if product.is_a?(Storefront::SampleProducts::Sample) %>
      <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-stone-200 via-stone-100 to-stone-200 text-stone-400">
        <%= render_svg("photo.svg", styles: "w-10 h-10") rescue tag.span("·", class: "text-3xl") %>
      </div>
    <% elsif product.images.attached? %>
      <%= image_tag product.images.first.variant(resize_to_fill: [ 500, 500 ]),
            alt: product.name,
            class: "h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" %>
    <% else %>
      <div class="flex h-full w-full items-center justify-center text-gray-400">
        <%= render_svg("photo.svg", styles: "w-10 h-10") rescue tag.span("·", class: "text-3xl") %>
      </div>
    <% end %>
  </div>

  <div class="mt-3 flex items-start justify-between gap-2">
    <h3 class="text-sm leading-snug" style="font-family: var(--sp-font-heading);"><%= product.name %></h3>
    <span class="shrink-0 text-sm text-gray-500"><%= number_to_currency(product.price, precision: 0) %></span>
  </div>
</div>
