<% content_for :title, "New product" %>

<%= turbo_frame_tag "modal" do %>
  <div data-controller="modal">
    <div data-modal-target="overlay" data-action="click->modal#close" class="fixed inset-0 z-[60] bg-black/40 transition-opacity duration-300 ease-out opacity-0"></div>
    <div data-modal-target="sidebar" class="fixed inset-x-0 bottom-0 z-[70] w-full md:w-[600px] md:left-1/2 md:top-1/2 md:bottom-auto md:-translate-x-1/2 md:-translate-y-1/2 max-h-[92vh] md:max-h-[90vh] bg-white shadow-2xl rounded-t-2xl md:rounded-2xl overflow-hidden flex flex-col transition-all duration-300 ease-out opacity-0 translate-y-full md:translate-y-4 md:scale-95 ring-1 ring-black/5">
      <div class="flex items-center justify-between p-4 border-b border-gray-200 text-black">
        <div class="flex flex-col border-gray-200 w-full">
          <div class="flex justify-between items-center mb-1">
            <h1 class="font-bold text-lg">Nuevo producto</h1>
            <button type="button" data-action="click->modal#close"
                    class="p-2 rounded-full bg-gray-200 hover:bg-gray-300 transition duration-200">
              <%= render_svg("close.svg") %>
            </button>
          </div>
          <p class="text-sm text-gray-500">Completa los detalles del producto</p>
        </div>
      </div>
      <div class="flex-1 overflow-y-auto p-5 bg-white scrollbar-hide">
        <%= render "form", product: @product %>
      </div>
    </div>
  </div>
<% end %>