<%= form_with(model: [:admin, product], class: "space-y-6 w-full") do |form| %>
  <div data-controller="image-preview" data-image-preview-max-files-value="2">
    <div class="mb-2 flex gap-1">
      <%= form.label :images, "Imágenes", class: "block text-sm font-medium leading-6 text-[#1A2B3C]" %>
      <span class="text-red-500">*</span>
      <span data-image-preview-target="counter" class="ml-auto text-xs text-gray-400">0 / 2</span>
    </div>

    <% if product.persisted? && product.images.attached? %>
      <div class="mb-3">
        <p class="mb-2 text-xs text-gray-500">Imágenes actuales:</p>

        <div class="flex flex-wrap gap-3">
          <% product.images.each do |img| %>
            <div class="relative h-20 w-20 overflow-hidden rounded-xl shadow-sm ring-1 ring-gray-200">
              <%= image_tag img, class: "w-full h-full object-cover" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <div
      data-image-preview-target="dropzone"
      data-action="dragover->image-preview#dragover dragleave->image-preview#dragleave drop->image-preview#drop"
      class="
        relative cursor-pointer rounded-xl border-2 border-dashed border-gray-200 p-6 text-center transition-all
        hover:border-[#10B981]
      "
      onclick="this.querySelector('input[type=file]').click()"
    >
      <div data-placeholder>
        <%= render_svg("upload.svg", styles: "mx-auto h-10 w-10 text-gray-300") %>

        <p class="mt-2 text-sm text-gray-500">
          Arrastra tus imágenes aquí o <span class="font-medium text-[#10B981]">haz clic para seleccionar</span>
        </p>

        <p class="mt-1 text-xs text-gray-400">JPG, PNG o WebP · Máx. 10 MB · Hasta 2 imágenes</p>
      </div>

      <%= form.file_field :images,
          multiple: true,
          accept: "image/jpeg,image/png,image/webp",
          data: { image_preview_target: "input", action: "change->image-preview#selectFiles" },
          class: "sr-only",
          direct_upload: true %>
    </div>

    <div data-image-preview-target="preview" class="mt-3 flex flex-wrap gap-3"></div>

    <%= display_field_errors(product, :images) %>
  </div>

  <div>
    <div class="mb-2 flex gap-1">
      <%= form.label :name, "Nombre", class: "block text-sm font-medium leading-6 text-[#1A2B3C]" %>
      <span class="text-red-500">*</span>
    </div>

    <div class="relative rounded-md shadow-sm">
      <%= form.text_field :name,
          placeholder: "Nombre del producto",
          class: "block w-full px-3.5 py-3 text-sm text-[#1a1a2e] bg-[#fafafa] border-[1.5px] border-[#e5e5ec] rounded-[10px] outline-none transition-all duration-200 placeholder:text-[#b0b0c4] focus:border-[#10B981] focus:ring-[3px] focus:ring-[#10B981]/15 focus:bg-white #{'border-red-300 focus:border-red-500 focus:ring-red-500/20' if product.errors[:name].any?}" %>
    </div>

    <%= display_field_errors(product, :name) %>
  </div>

  <div>
    <div class="mb-2 flex gap-1">
      <%= form.label :price, "Precio", class: "block text-sm font-medium leading-6 text-[#1A2B3C]" %>
      <span class="text-red-500">*</span>
    </div>

    <div class="relative rounded-md shadow-sm">
      <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3"></div>

      <%= form.text_field :price,
          placeholder: "$ 0.00",
          class: "block w-full px-3.5 py-3 text-sm text-[#1a1a2e] bg-[#fafafa] border-[1.5px] border-[#e5e5ec] rounded-[10px] outline-none transition-all duration-200 placeholder:text-[#b0b0c4] focus:border-[#10B981] focus:ring-[3px] focus:ring-[#10B981]/15 focus:bg-white #{'border-red-300 focus:border-red-500 focus:ring-red-500/20' if product.errors[:price].any?}" %>
    </div>

    <%= display_field_errors(product, :price) %>
  </div>

  <div>
    <div class="mb-2 flex gap-1">
      <%= form.label :description, "Descripción", class: "block text-sm font-medium leading-6 text-[#1A2B3C]" %>
      <span class="text-red-500">*</span>
    </div>

    <div class="relative rounded-md shadow-sm">
      <%= form.text_area :description,
          rows: 4,
          placeholder: "Describe materiales, tamaños, colores disponibles...",
          class: "block w-full px-3.5 py-3 text-sm text-[#1a1a2e] bg-[#fafafa] border-[1.5px] border-[#e5e5ec] rounded-[10px] outline-none transition-all duration-200 placeholder:text-[#b0b0c4] focus:border-[#10B981] focus:ring-[3px] focus:ring-[#10B981]/15 focus:bg-white #{'border-red-300 focus:border-red-500 focus:ring-red-500/20' if product.errors[:description].any?}" %>
    </div>

    <%= display_field_errors(product, :description) %>
  </div>

  <%= render Buttons::Component.new(
    text: "Crear producto",
    type: "submit",
    pill: true,
    full_width: true,
  ) %>
<% end %>
