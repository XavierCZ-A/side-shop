<div
  data-dropdown-target="menu"
  class="
    ring-opacity-5 pointer-events-none absolute top-full right-0 z-50 mt-2 hidden w-56 -translate-y-2 rounded-lg
    bg-white opacity-0 shadow-lg ring-1 ring-black transition-all duration-200 ease-out
  "
>
  <div class="border-b border-gray-200 p-4">
    <p class="truncate text-sm font-medium text-gray-900"><%= current_user.store.name %></p>
    <p class="mt-0.5 truncate text-xs text-gray-500"><%= current_user.email_address %></p>
  </div>

  <div class="py-1">
    <%= link_to admin_customize_path, class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors duration-150" do %>
      <span class="mr-3"><%= render_svg("paint.svg", styles: "w-5 h-5") %></span> Personaliza tu tienda
    <% end %>
  </div>

  <div class="py-1">
    <%= link_to admin_billing_path, class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors duration-150" do %>
      <span class="mr-3"><%= render_svg("user.svg", styles: "w-5 h-5") %></span> Gestionar subscripción
    <% end %>
  </div>

  <div class="border-t border-gray-100 py-1">
    <%= button_to session_path, method: :delete, class: "w-full flex items-center px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition-colors duration-150 text-left cursor-pointer" do %>
      <span class="mr-3"><%= render_svg("logout.svg", styles: "w-5 h-5 text-red-400") %></span> Cerrar sesión
    <% end %>
  </div>
</div>
