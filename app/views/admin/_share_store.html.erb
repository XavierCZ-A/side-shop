<%= render Buttons::Component.new(
  text: "Compartir Tienda",
  icon: render_svg("share.svg", styles: "w-4 h-4"),
  pill: true,
  classes: "[&_span:not(.shrink-0)]:hidden md:[&_span:not(.shrink-0)]:inline",
  commandfor: "share-store-dialog",
  command: "show-modal"
) %>

<dialog id="share-store-dialog" closedby="any" role="alertdialog" aria-labelledby="dialog-title" aria-describedby="dialog-desc" class="z-[70] w-[calc(100%-2rem)] max-w-sm sm:max-w-md m-auto p-0 rounded-3xl shadow-2xl bg-white backdrop:bg-black/40 open:animate-in open:fade-in open:zoom-in-95 backdrop:open:animate-in backdrop:open:fade-in duration-200 border-0">

  <header class="flex items-center justify-between p-5 border-b border-gray-100">
    <div>
      <h2 id="dialog-title" class="text-lg sm:text-xl font-bold text-gray-900">Compartir Tienda</h2>
      <p id="dialog-desc" class="text-xs sm:text-sm text-gray-500 mt-1">Tu tienda está lista para recibir visitas.</p>
    </div>
    <button type="button" commandfor="share-store-dialog" command="close" class="p-2 -mr-2 text-gray-400 hover:text-gray-600 rounded-full hover:bg-gray-100 transition-colors focus:outline-none focus:ring-2 focus:ring-gray-200 active:bg-gray-200">
      <span class="sr-only">Cerrar</span>
      <%= render_svg("close.svg", styles: "w-5 h-5") %>
    </button>
  </header>

  <div class="p-5 sm:p-6 space-y-6 sm:space-y-7">
    <section>
      <label class="text-[11px] sm:text-xs font-bold text-gray-500 uppercase tracking-wider mb-2 block">Link público</label>
      <div class="rounded-2xl">
        <div class="flex items-center gap-2">
          <div class="flex-1 relative">
            <input type="text" readonly value="<%= @store_url %>" 
                   class="w-full bg-white border border-gray-200 rounded-xl pl-3 pr-3 py-3 text-gray-700 text-sm truncate font-medium focus:outline-none focus:ring-2 focus:ring-blue-500/20 shadow-sm transition-shadow">
          </div>
          <%= render Clipboard::Component.new(
            text: @store_url,
            icon_only: true,
            variant: :ghost,
            size: :lg,
          ) %>
        </div>
      </div>
    </section>
    
    <section class="flex flex-col gap-3">
      <div>
        <label class="text-[11px] sm:text-xs font-bold text-gray-500 uppercase tracking-wider mb-2 block">Tienda</h2>
      </div>
      <div>
        <%= link_to store_root_url(subdomain: @store.slug), target: "_blank", class: "flex flex-col w-full items-center justify-center gap-2 sm:gap-3 p-3 sm:p-4 rounded-2xl border-2 border-gray-500 bg-white hover:bg-gray-50 hover:border-gray-300 hover:shadow-md transition-all group active:scale-95" do %>
          <div class="p-2 sm:p-2.5 bg-accent/15 text-accent rounded-xl group-hover:scale-110 group-hover:bg-accent/25 transition-all duration-300">
            <%= render_svg("store.svg", styles: "w-4 h-4") %>
          </div>
          <span class="text-[13px] sm:text-sm font-semibold text-gray-700">Ver Tienda</span>
        <% end %>
      </div>

    </section>

    <section>
      <div class="flex items-center gap-3 mb-4">
        <div class="h-px bg-gray-200 flex-1"></div>
        <span class="text-[10px] sm:text-xs font-semibold text-gray-400 uppercase tracking-wider">Compartir en redes</span>
        <div class="h-px bg-gray-200 flex-1"></div>
      </div>
      
      <div class="grid grid-cols-3 gap-2 sm:gap-3">
        <%= link_to "https://www.facebook.com/", target: "_blank", class: "flex flex-col items-center gap-2 p-2 sm:p-3 rounded-2xl hover:bg-gray-50 border border-transparent hover:border-gray-100 transition-all group active:scale-95" do %>
          <div class="w-10 h-10 sm:w-12 sm:h-12 bg-[#1877F2]/10 rounded-full flex items-center justify-center transition-all duration-300">
            <%= render_svg("facebook.svg", styles: "w-5 h-5 text-[#1877F2] transition-colors") %>
          </div>
          <span class="text-[11px] sm:text-xs font-semibold text-gray-600">Facebook</span>
        <% end %>
        
        <%= link_to "https://www.instagram.com/", target: "_blank", class: "flex flex-col items-center gap-2 p-2 sm:p-3 rounded-2xl hover:bg-gray-50 border border-transparent hover:border-gray-100 transition-all group active:scale-95" do %>
          <div class="w-10 h-10 sm:w-12 sm:h-12 bg-gradient-to-tr from-[#FFDC80] via-[#FD1D1D] to-[#833AB4] opacity-90 rounded-full flex items-center justify-center transition-all duration-300 p-[2px]">
            <div class="w-full h-full bg-white rounded-full flex items-center justify-center transition-colors duration-300">
              <%= render_svg("instagram.svg", styles: "w-5 h-5 text-[#E4405F] transition-colors") %>
            </div>
          </div>
          <span class="text-[11px] sm:text-xs font-semibold text-gray-600">Instagram</span>
        <% end %>
        
        <%= link_to "https://web.whatsapp.com/", target: "_blank", class: "flex flex-col items-center gap-2 p-2 sm:p-3 rounded-2xl hover:bg-gray-50 border border-transparent hover:border-gray-100 transition-all group active:scale-95" do %>
          <div class="w-10 h-10 sm:w-12 sm:h-12 bg-[#25D366]/10 rounded-full flex items-center justify-center transition-all duration-300">
            <%= render_svg("whatsapp.svg", styles: "w-5 h-5 text-[#25D366] group-hover:text-white transition-colors") %>
          </div>
          <span class="text-[11px] sm:text-xs font-semibold text-gray-600">WhatsApp</span>
        <% end %>
      </div>
    </section>

  </div>
</dialog>
