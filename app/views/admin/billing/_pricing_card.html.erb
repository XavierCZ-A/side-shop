<article class="flex h-full flex-col rounded-xl border p-4 <%= is_current_plan ? "border-[#10B981] bg-[#10B981]/5" : "border-border bg-white" %>">
  <div class="mb-3 flex items-start justify-between gap-2">
    <div>
      <p class="text-sm font-semibold text-[#1A2B3C]"><%= plan[:label] %></p>
      <p class="mt-1 text-lg font-bold text-[#1A2B3C]"><%= plan[:amount] %></p>
    </div>

    <% if is_current_plan %>
      <span class="rounded-full bg-[#10B981]/15 px-2.5 py-1 text-[11px] font-semibold text-[#1A2B3C]">Actual</span>
    <% end %>
  </div>

  <ul class="mb-8 flex-1 space-y-3">
    <% plan[:features].each do |feature| %>
      <li class="flex items-center gap-3 text-sm <%= feature[:included] ? 'text-foreground' : 'text-muted-foreground/60' %>">
        <% if feature[:included] %>
          <%= render_svg("check_circle.svg", styles: "w-5 h-5 flex-shrink-0 text-accent") %>
        <% else %>
          <%= render_svg("close.svg", styles: "w-5 h-5 flex-shrink-0 text-muted-foreground/40") %>
        <% end %>

        <%= feature[:label] %>
      </li>
    <% end %>
  </ul>

  <% if is_current_plan %>
    <div
      class="
        rounded-lg border border-border bg-secondary px-3 py-2 text-center text-sm font-medium
        text-secondary-foreground
      "
    >
      Este es tu plan actual
    </div>
  <% else %>
    <%= button_to admin_subscriptions_path,
        method: :post,
        params: { plan: plan[:name] }, data: { turbo: false },
        class: "w-full btn-primary" do %>
      Elegir plan
    <% end %>
  <% end %>
</article>
