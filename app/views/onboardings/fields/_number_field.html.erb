<!-- app/views/onboardings/fields/_number_field.html.erb -->
<div class="w-full">
  <%= form.label field[:name], field[:label], class: "block text-sm font-semibold text-gray-700 mb-2" %>
  
  <div class="relative">
    <%= form.number_field field[:name], 
      class: "w-full px-3.5 py-3 text-sm text-[#1a1a2e] bg-[#fafafa] border-[1.5px] border-[#e5e5ec] rounded-[10px] outline-none transition-all duration-200 placeholder:text-[#b0b0c4] focus:border-[#10B981] focus:ring-[3px] focus:ring-[#10B981]/15 focus:bg-white",
      placeholder: field[:placeholder],
      required: field[:required],
      min: 0 %>
  </div>
</div>