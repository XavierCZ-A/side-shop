<!-- app/views/onboardings/fields/_select.html.erb -->
<div class="w-full">
  <%= form.label field[:name], field[:label], class: "block text-sm font-semibold text-gray-700 mb-3" %>
  
  <!-- Industry Grid Cards -->
  <div class="grid grid-cols-2 gap-3">
    <% industry_icons = { 
      "Ropa" => "👗", 
      "Alimentos" => "🍕", 
      "Servicios" => "🛠️", 
      "Otro" => "✨" 
    } %>
    
    <% field[:options].each_with_index do |option, index| %>
      <% element_id = "#{field[:name]}_#{option.parameterize.underscore}" %>
      
      <div class="relative">
        <%= form.radio_button field[:name], option,
            id: element_id,
            class: "peer sr-only",
            checked: index == 0,
            required: field[:required],
            data: { action: "change->onboarding#updateIndustry" }
        %>
        
        <label 
          for="<%= element_id %>"
          class="block p-4 bg-white/60 backdrop-blur-sm border-2 border-gray-200 rounded-2xl cursor-pointer transition-all duration-200 hover:bg-white hover:border-gray-300 peer-checked:border-[#10B981] peer-checked:bg-[#ECFDF5] peer-checked:shadow-md peer-checked:shadow-[#10B981]/20"
        >
          <div class="text-center">
            <span class="text-3xl block mb-2"><%= industry_icons[option] || "📦" %></span>
            <span class="font-semibold text-[#1A2B3C] text-sm"><%= option %></span>
          </div>
        </label>
      </div>
    <% end %>
  </div>

  <!-- Other Industry Input (shown when "Otro" is selected) -->
  <div data-onboarding-target="otherInput" class="hidden mt-4 transition-all duration-300">
    <label class="block text-sm font-medium text-gray-700 mb-1">Especifica tu industria:</label>
    <%= form.text_field :other_industry, 
        class: "w-full px-3.5 py-3 text-sm text-[#1a1a2e] bg-[#fafafa] border-[1.5px] border-[#e5e5ec] rounded-[10px] outline-none transition-all duration-200 placeholder:text-[#b0b0c4] focus:border-[#10B981] focus:ring-[3px] focus:ring-[#10B981]/15 focus:bg-white",
        placeholder: "Por ejemplo: Joyería, Tecnología, Mascotas..." %>
  </div>
</div>