<main data-controller="onboarding" class="min-h-screen flex flex-col bg-gradient-to-br from-[#F3F4F6] via-[#EAF2F8] to-[#ECFDF5] relative overflow-hidden">

  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-40 -right-40 w-80 h-80 bg-[#1A2B3C]/20 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-primary/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-pink-200/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 2s;"></div>
  </div>

  <div class="relative z-10 pt-6 pb-4 px-4">
    <div class="max-w-md mx-auto">
      <div class="flex items-center justify-between">
        <% @onboarding.steps.each_with_index do |step, index| %>
          <div class="flex items-center">

            <div 
              class="w-10 h-10 rounded-full flex items-center justify-center font-semibold text-sm transition-all duration-300 shadow-sm"
              data-onboarding-target="indicator"
              data-step-index="<%= index %>"
            >
              <% case step.id %>
              <% when "welcome" %>
                <span class="text-lg">👋</span>
              <% when "store_info" %>
                <span class="text-lg">🏪</span>
              <% when "store_color" %>
                <span class="text-lg">🎨</span>
              <% when "product" %>
                <span class="text-lg">📦</span>
              <% else %>
                <%= index + 1 %>
              <% end %>
            </div>
          </div>
          
          <% unless index == @onboarding.steps.length - 1 %>

            <div class="flex-1 h-1 mx-2 rounded-full bg-gray-200 transition-all duration-300">
              <div 
                class="h-full rounded-full bg-[#10B981] transition-all duration-500"
                data-onboarding-target="progressLine"
                data-line-index="<%= index %>"
                style="width: 0%;"
              ></div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="flex-1 flex items-center justify-center px-4 py-6 relative z-10">
    <%= form_with model: @onboarding, class: "w-full" do |form| %>
      <% @onboarding.steps.each_with_index do |step, index| %>
        <div
          id="<%= dom_id(step) %>"
          class="<%= class_names("w-full max-w-lg mx-auto transition-all duration-500 ease-out", { "hidden": index != 0 }) %>"
          data-onboarding-target="step"
          data-step-index="<%= index %>"
        >
          <div class="bg-white/70 backdrop-blur-xl rounded-3xl shadow-xl shadow-[#1A2B3C]/10 border border-white/50 p-6 sm:p-8">
            <div class="text-center mb-6">
              <h2 class="text-2xl sm:text-3xl font-bold text-[#1A2B3C] mb-2">
                <%= step.title %>
              </h2>
              
              <%= tag.p step.description, class: "text-base text-gray-600" if step.description.present? %>
            </div>

            <div class="space-y-5">
              <% step.fields.each do |field| %>
                <%= render partial: "onboardings/fields/#{field[:type]}", locals: { form: form, field: field } %>
                
                <% if field[:hint].present? %>
                  <p class="text-sm text-center text-gray-500">
                    <%= field[:hint] %>
                  </p>
                <% end %>
              <% end %>
            </div>

            <div class="mt-8">
              <% if index == @onboarding.steps.length - 1 %>
                <%= render Buttons::Component.new(
                  text: "Crear mi tienda",
                  type: "submit",
                  full_width: true,
                ) %>
              <% else %>
                <%= render Buttons::Component.new(
                  text: "Continuar",
                  icon: render_svg("arrow_right.svg", styles: "w-4 h-4"),
                  icon_position: :right,
                  full_width: true,
                  data: { action: "onboarding#continue", step: step.id }
                ) %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>


  <div class="relative z-10 pb-6 text-center">
    <p class="text-sm text-gray-500">
      Paso <span data-onboarding-target="currentStep">1</span> de <%= @onboarding.steps.length %>
    </p>
  </div>
</main>