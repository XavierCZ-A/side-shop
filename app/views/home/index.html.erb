<nav class="sticky top-0 z-50 w-full border-b border-[#E5E7EB] backdrop-blur-md bg-white/90">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">

      <div class="flex-shrink-0 flex items-center gap-2">
        <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center text-white">
            <%= render_svg("cart.svg", styles: "w-5 h-5") %>
        </div>
        <span class="hidden sm:inline text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-gray-900 to-gray-700">PocketShop</span>
      </div>

      <div class="hidden md:flex items-center space-x-8">
        <a href="#features" class="text-muted-foreground hover:text-foreground transition-colors font-medium text-sm">Características</a>
        <a href="#pricing" class="text-muted-foreground hover:text-foreground transition-colors font-medium text-sm">Planes</a>
        <a href="#faq" class="text-muted-foreground hover:text-foreground transition-colors font-medium text-sm">Preguntas</a>
      </div>

      <div class="flex items-center gap-4">
        <%= render Buttons::Component.new(
          text: "Iniciar sesión",
          full_width: true,
          pill: true,
          variant: :outline,
          href: new_session_path
        ) %>
        <%= render Buttons::Component.new(
          text: "Crear tienda",
          full_width: true,
          pill: true,
          href: new_user_path
        ) %>
      </div>
    </div>
  </div>
</nav>

<section class="relative overflow-hidden pt-12 pb-16 lg:pt-20 lg:pb-32 bg-secondary/30">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl">
      <div class="absolute top-20 right-0 w-[500px] h-[500px] bg-primary/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-[#10B981]/10 rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">
      
      <div class="max-w-2xl text-center lg:text-left mx-auto lg:mx-0">
        <div class="inline-flex items-center gap-2 bg-[#ECFDF5] px-3 py-1 rounded-full border border-[#A7F3D0] mb-6">
          <span class="text-xs font-semibold text-accent tracking-wide uppercase">Ideal para emprendedores</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-foreground tracking-tight leading-[1.1] mb-6">
          Tu tienda online <span class="block text-primary">en un solo link.</span>
        </h1>
        
        <p class="text-lg sm:text-xl text-muted-foreground mb-8 leading-relaxed max-w-lg mx-auto lg:mx-0">
          Olvídate de Shopify o WooCommerce. Sube tus 5, 10 o 15 productos top y comparte tu link. Simple, rápido y hermoso.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4 mb-10">
          <%= render Buttons::Component.new(
              text: "Comenzar gratis",
              variant: :accent,
              size: :lg,
              href: new_user_path
          ) %>

          <%= render Buttons::Component.new(
              text: "Ver demo",
              size: :lg,
              variant: :primary,
              href: "#"
          ) %>
        </div>

        <div class="flex flex-wrap items-center justify-center lg:justify-start gap-x-6 gap-y-3 text-sm text-muted-foreground">
          <div class="flex items-center gap-2">
            <%= render_svg("check_circle.svg", styles: "w-5 h-5 text-success") %>
            <span>Sin tarjetas de crédito</span>
          </div>
          <div class="flex items-center gap-2">
           <%= render_svg("check_circle.svg", styles: "w-5 h-5 text-success") %>
            <span>Configuración en 2 min</span>
          </div>
        </div>
      </div>

      <!-- Right Content (Mockup Visual) -->
      <div class="relative lg:h-[600px] flex items-center justify-center">
        <!-- Abstract Shapes backing -->
        <div class="absolute inset-0 bg-gradient-to-tr from-[#EAF2F8] to-white rounded-[3rem] -rotate-3 scale-95 border border-primary/10 shadow-sm"></div>
        
        <!-- Main Card Container (Floating) -->
        <div class="relative w-full max-w-md bg-white rounded-[2rem] shadow-2xl shadow-primary/10 border border-gray-100 p-6 rotate-2 hover:rotate-0 transition-transform duration-500">
            <!-- Profile Header -->
            <div class="flex items-center justify-between mb-6">
                <div class="flex items-center gap-3">
                   <div class="w-12 h-12 rounded-full bg-muted overflow-hidden relative">
                        <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?ixlib=rb-1.2.1&ixid=eyJhcHBfaWQiOjEyMDd9&auto=format&fit=facearea&facepad=2&w=256&h=256&q=80" alt="Sarah" class="w-full h-full object-cover">
                   </div>
                   <div>
                       <h3 class="font-bold text-foreground">Tienda de Sarah</h3>
                       <p class="text-xs text-muted-foreground">@sarah_crafts</p>
                   </div>
                </div>
                <button class="bg-primary text-white text-xs font-semibold px-4 py-1.5 rounded-full">Seguir</button>
            </div>

            <!-- Product Grid Mockup -->
            <div class="grid grid-cols-2 gap-4">
                <div class="aspect-square bg-[#F3F4F6] rounded-xl"></div>
                <div class="aspect-square bg-[#F3F4F6] rounded-xl"></div>
                <div class="aspect-square bg-[#F3F4F6] rounded-xl"></div>
                <div class="aspect-square bg-[#F3F4F6] rounded-xl"></div>
            </div>
            
        </div>
      </div>

    </div>
  </div>
</section>

<section id="pricing" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-5xl font-black text-foreground tracking-tight mb-4">
        Planes simples para <span class="text-primary">crecer contigo</span>
      </h2>
      <p class="text-xl text-muted-foreground">
        Comienza gratis y mejora tu plan a medida que aumenten tus ventas. Sin comisiones ocultas por transacción.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 max-w-7xl mx-auto">
      <% @plans.each do |plan| %>
        <%= render "shared/pricing_card", plan: plan %>
      <% end %>
    </div>
  </div>
</section>

<section id="faq" class="relative overflow-hidden pt-12 pb-16 lg:pt-20 lg:pb-32 bg-secondary/30">
    <div>
      <h1 class="text-3xl md:text-5xl font-black text-foreground tracking-tight mb-4 text-center">
        Respuestas a tus dudas
      </h1>
      <p class="text-xl text-muted-foreground text-center mb-12">
        Aquí encontrarás respuestas a las preguntas más frecuentes sobre PocketShop.
      </p>
    </div>

    <div class="max-w-3xl mx-auto">
      <%= render Accordion::Component.new(icon: :plus_minus, variant: :bordered, allow_multiple: true) do |accordion| %>
        <% accordion.with_item(title: "¿Realmente puedo tener mi tienda en 5 minutos?", default_open: false) do %>
          ¡Sí! Solo necesitas el nombre de tu negocio y subir tu primer producto. Nuestro asistente inteligente configura el diseño y los pagos por ti para que puedas compartir tu link de inmediato.
        <% end %>
        <% accordion.with_item(title: "¿Necesito saber programar o ser diseñador?", default_open: false) do %>
          Para nada. Si sabes usar Facebook o WhatsApp, sabes usar nuestra plataforma. Es 100% visual y amigable.
        <% end %>
        <% accordion.with_item(title: "¿Qué métodos de pago puedo ofrecer a mis clientes?", default_open: false) do %>
          Puedes aceptar pagos por WhatsApp, transferencias bancarias (SPEI) y depósitos en OXXO. También puedes activar pagos con tarjeta de crédito y débito de forma sencilla.
        <% end %>
        <% accordion.with_item(title: "¿Cobran comisión por cada venta?", default_open: false) do %>
          Nosotros no cobramos comisiones por tus ventas. Tu dinero es tuyo. Solo pagas tu suscripción mensual [o la comisión de la pasarela si usas Stripe/Mercado Pago].
        <% end %>
        <% accordion.with_item(title: "¿Que pasa si no me gusta? ¿Hay periodo de prueba?", default_open: false) do %>
          Toda la plataforma es gratis, no necesitas tarjeta de crédito. Puedes probarla sin riesgo y decidir si quieres mejorar tu plan después.
        <% end %>
      <% end %>
    </div>
</section>