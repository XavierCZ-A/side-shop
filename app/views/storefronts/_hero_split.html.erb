<section class="hero-variant hero-variant--split">
  <div class="mx-auto grid max-w-6xl grid-cols-1 gap-8 px-6 py-16 sm:py-20 md:grid-cols-2 md:items-center">
    <div>
      <p class="mb-3 text-[10px] tracking-[0.4em] text-gray-500 uppercase">Nuevo</p>

      <h1 class="mb-5 text-4xl leading-tight sm:text-5xl" style="font-family: var(--sp-font-heading);">
        <%= store.name %>
      </h1>

      <% if store.description.present? %>
        <p class="mb-7 text-base leading-relaxed text-gray-600">
          <%= truncate(store.description, length: 160) %>
        </p>
      <% else %>
        <p class="mb-7 text-base leading-relaxed text-gray-600 italic">
          Diseñado a mano, pensado para durar.
        </p>
      <% end %>

      <button
        class="inline-block px-7 py-3 text-sm font-medium text-white transition-opacity hover:opacity-90"
        style="background-color: var(--sp-color-primary); border-radius: var(--sp-radius);"
      >
        Ver colección
      </button>
    </div>

    <div class="relative aspect-[4/5] w-full overflow-hidden shadow-sm" style="border-radius: var(--sp-radius);">
      <% if store.image.attached? %>
        <%= image_tag store.image, alt: store.name, class: "h-full w-full object-cover" %>
      <% else %>
        <div class="absolute inset-0 bg-gradient-to-br from-stone-300 via-stone-200 to-stone-300"></div>
      <% end %>
    </div>
  </div>
</section>
