<% content_for :title, "Carrito de Compras" %>

<div class="min-h-screen bg-[#F3F4F6]">
  <div class="bg-white border-b border-gray-200 sticky top-0 z-20">
    <div class="max-w-7xl mx-auto px-4 py-4 sm:py-5">
      <div class="flex items-center gap-3">
        <%= link_to store_path(@store.slug), class: "p-1.5 rounded-full hover:bg-[#F3F4F6] transition-colors" do %>
          <%= render_svg("arrow_left.svg", styles: "w-5 h-5 text-gray-700") %>
        <% end %>
        <div>
          <h1 class="text-xl sm:text-2xl font-bold text-[#1A2B3C]">Carrito de Compras</h1>
          <p class="text-sm text-gray-500"><span id="cart_header_count"><%= @cart&.line_items&.sum(:quantity) %></span> productos</p>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 py-6 lg:py-8">
    <div class="flex flex-col lg:flex-row gap-6 lg:gap-8">

      <div class="flex-1 min-w-0">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">

          <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
            <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Productos</span>
            <%= button_to carts_path(@store.slug), method: :delete, class: "flex items-center gap-1.5 text-xs text-gray-400 hover:text-red-500 transition-colors cursor-pointer group" do %>
              <%= render_svg("trash.svg", styles: "w-4 h-4") %>
              <span>Vaciar carrito</span>
            <% end %>
          </div>

          <% @products.each do |line_item| %>
            <%= render "carts/products/product_cart_info", product: line_item %>
          <% end %>

        </div>
      </div>


      <div class="w-full lg:w-[380px] shrink-0">
        <div class="lg:sticky lg:top-24 space-y-4">

          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5 sm:p-6">
            <h2 class="text-lg font-bold text-[#1A2B3C] mb-4 pb-4 border-b border-gray-100">Resumen del pedido</h2>


            <div class="space-y-3 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-500">Subtotal (<span id="cart_summary_count"><%= @cart.line_items.sum(:quantity) %></span> productos)</span>
                <span id="cart_subtotal" class="font-medium text-[#1A2B3C]"><%= number_to_currency(@cart.total_price) %></span>
              </div>

              <div class="flex justify-between">
                <span class="text-gray-500">Envío</span>
                <span class="font-medium text-emerald-600">Gratis</span>
              </div>
            </div>


            <div class="flex justify-between items-center mt-4 pt-4 border-t border-gray-200">
              <span class="text-base font-bold text-[#1A2B3C]">Total</span>
              <span id="cart_total" class="text-xl sm:text-2xl font-bold text-[#1A2B3C]"><%= number_to_currency(@cart.total_price) %></span>
            </div>

            <div class="mt-5 pt-4 border-t border-gray-100">
              <div class="flex items-center gap-2 mb-3">
                <%= render_svg("promotion_code.svg", styles: "w-4 h-4 text-gray-500") %>
                <span class="text-sm font-semibold text-gray-700">Código promocional</span>
              </div>
              <div class="flex gap-2">
                <input type="text" placeholder="Ingresa tu código" class="flex-1 px-3 py-2.5 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent placeholder-gray-400 transition-all">
                <%= render Buttons::Component.new(
                  text: "Aplicar"
                ) %>
              </div>
            </div>

            <div class="flex mt-6 gap-3">
              <%= render Buttons::Component.new(
                text: "WhatsApp",
                icon: render_svg("whatsapp.svg", styles: "w-4 h-4"),
                icon_position: :left,
                full_width: true,
                href: whatsapp_link("3315129273", @cart.line_items),
                target: "_blank",
                classes: "[&_span:not(.shrink-0)]:hidden md:[&_span:not(.shrink-0)]:inline"
              ) %>

                <%= render Buttons::Component.new(
                text: "Proceder al pago",
                full_width: true,
                ) %>
            </div>

            <div class="mt-4 space-y-2">
              <div class="flex items-center gap-2 text-xs text-gray-500">
                <%= render_svg("shield_check.svg", styles: "w-4 h-4 text-emerald-500 shrink-0") %>
                <span>Pago 100% seguro</span>
              </div>
            </div>
          </div>

          <div class="flex items-center justify-center gap-3">
            <div class="flex items-center justify-center px-4 py-2.5 bg-white rounded-lg border border-gray-100 shadow-sm min-w-[80px]">
              <span class="text-xs font-bold text-[#1A1F71] tracking-wide">VISA</span>
            </div>
            <div class="flex items-center justify-center px-4 py-2.5 bg-white rounded-lg border border-gray-100 shadow-sm min-w-[80px]">
              <span class="text-xs font-bold text-gray-700 tracking-wide">Mastercard</span>
            </div>
            <div class="flex items-center justify-center px-4 py-2.5 bg-white rounded-lg border border-gray-100 shadow-sm min-w-[80px]">
              <span class="text-xs font-bold text-[#003087] tracking-wide">PayPal</span>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</div>