<div class="min-h-screen bg-gradient-to-b from-[#EAF2F8] via-white to-white">
  <div class="max-w-4xl mx-auto px-4 py-16 sm:py-24">
    <div class="text-center">
        
      <div class="mb-8 flex justify-center">
        <svg class="w-64 h-64 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" opacity="0.3"/>
          <line x1="4" y1="4" x2="20" y2="20" stroke-width="2" stroke="currentColor" class="text-red-500"/>
        </svg>
      </div>

      <h1 class="text-5xl sm:text-6xl font-extrabold text-[#1A2B3C] mb-4">
        Oops...
      </h1>
      
      <p class="text-xl text-gray-600 mb-2">
        Esta tienda no existe
      </p>
      
      <p class="text-gray-500 mb-10 max-w-md mx-auto">
        Puede que el enlace esté mal escrito o que la tienda haya sido eliminada.
      </p>

      <%= link_to root_path, class: "inline-block group relative" do %>
        <div class="absolute inset-0 bg-gradient-to-r from-[#1A2B3C] to-[#10B981] rounded-xl blur opacity-75 group-hover:opacity-100 transition-opacity"></div>
        <div class="relative bg-gradient-to-r from-[#1A2B3C] to-[#10B981] text-white font-bold px-10 py-4 rounded-xl hover:shadow-2xl transition-all">
          ✨ Crear mi tienda gratis
        </div>
      <% end %>
    </div>
  </div>
</div>