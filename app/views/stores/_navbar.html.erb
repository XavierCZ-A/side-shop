<nav
  data-controller="navbar"
  class="sticky top-0 z-50 w-full border-b border-gray-200 bg-[#f9f8f5]/90 px-4 backdrop-blur-md transition-all duration-300 md:px-8"
>
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between">
    <a href="#top" class="group flex items-center gap-2.5">
      <span
        class="
          flex h-8 w-8 items-center justify-center rounded-full bg-primary font-serif text-xs font-bold
          text-primary-foreground transition-transform duration-300 group-hover:scale-105
        "
      >
        <%= current_store.name.first.upcase %>
      </span>
      <h2 class="font-serif text-base tracking-wide text-primary">
        <%= current_store.name.capitalize %>
      </h2>
    </a>

    <%# Desktop links %>
    <div class="hidden items-center gap-7 md:flex">
      <a href="#productos" class="nav-text">Tienda</a>
      <a href="#sobre" class="nav-text">Sobre</a>
      <% if current_store.whatsapp.present? %>
        <a href="https://wa.me/<%= current_store.whatsapp %>" target="_blank" rel="noopener" class="nav-text">Contacto</a>
      <% else %>
        <a href="#contacto" class="nav-text">Contacto</a>
      <% end %>
    </div>

    <%# Mobile hamburger button %>
    <button
      data-navbar-target="hamburger"
      data-action="click->navbar#toggle"
      class="
        flex h-10 w-10 items-center justify-center rounded-lg text-primary transition-colors hover:bg-gray-100
        md:hidden
      "
      aria-label="Menú"
    >
      <svg class="icon-open w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <%= render_svg("close.svg", styles: "icon-close w-5 h-5 hidden") %>
    </button>
  </div>

  <%# Mobile menu panel %>
  <div
    data-navbar-target="menu"
    class="hidden md:hidden"
  >
    <div class="flex flex-col gap-1 border-t border-gray-100 px-2 pb-4 pt-3">
      <a
        href="#productos"
        data-action="click->navbar#close"
        class="flex items-center rounded-xl px-3 py-3.5 text-base font-medium text-primary transition-colors hover:bg-gray-100"
      >
        Tienda
      </a>
      <a
        href="#sobre"
        data-action="click->navbar#close"
        class="flex items-center rounded-xl px-3 py-3.5 text-base font-medium text-primary transition-colors hover:bg-gray-100"
      >
        Sobre
      </a>
      <% if current_store.whatsapp.present? %>
        <a
          href="https://wa.me/<%= current_store.whatsapp %>"
          target="_blank"
          rel="noopener"
          data-action="click->navbar#close"
          class="flex items-center rounded-xl px-3 py-3.5 text-base font-medium text-primary transition-colors hover:bg-gray-100"
        >
          Contacto
        </a>
      <% else %>
        <a
          href="#contacto"
          data-action="click->navbar#close"
          class="flex items-center rounded-xl px-3 py-3.5 text-base font-medium text-primary transition-colors hover:bg-gray-100"
        >
          Contacto
        </a>
      <% end %>
    </div>
  </div>
</nav>
