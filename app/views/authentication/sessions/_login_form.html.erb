<%= form_with url: session_url, class: "w-full" do |form| %>
  <div class="mb-5">
    <div class="flex justify-between items-center mb-2">
      <label class="text-[0.8125rem] font-medium text-[#1a1a2e]" for="email_address">Correo Electrónico</label>
    </div>
    <%= form.email_field :email_address,
        required: true,
        autofocus: true,
        autocomplete: "username",
        placeholder: "tu@email.com",
        value: @email,
        id: "email_address",
          class: "block w-full px-3.5 py-3 text-sm text-[#1a1a2e] bg-[#fafafa] border-[1.5px] border-[#e5e5ec] rounded-[10px] outline-none transition-all duration-200 placeholder:text-[#b0b0c4] focus:border-violet-500 focus:ring-[3px] focus:ring-violet-500/12 focus:bg-white" %>
  </div>

  <div class="mb-5">
    <div class="flex justify-between items-center mb-2">
      <label class="text-[0.8125rem] font-medium text-[#1a1a2e]" for="password">Contraseña</label>
      <%= link_to "¿Olvidaste tu contraseña?", new_password_path, class: "text-xs text-violet-500 font-medium hover:text-violet-600 transition-colors" %>
    </div>
    <%= form.password_field :password,
        required: true,
        autocomplete: "current-password",
        placeholder: "••••••••",
        maxlength: 72,
        id: "password",
        class: "block w-full px-3.5 py-3 text-sm text-[#1a1a2e] bg-[#fafafa] border-[1.5px] border-[#e5e5ec] rounded-[10px] outline-none transition-all duration-200 placeholder:text-[#b0b0c4] focus:border-violet-500 focus:ring-[3px] focus:ring-violet-500/12 focus:bg-white" %>
  </div>

  <%= render Buttons::Component.new(
    text: "Entrar",
    type: "submit",
    full_width: true,
  ) %>
<% end %>
