<style>
  dialog {
    transition: transform 0.2s ease-out, opacity 0.2s ease-out, display 0.2s allow-discrete, overlay 0.2s allow-discrete;
    opacity: 0;
    transform: scale(0.95);
  }

  dialog::backdrop {
    transition: background-color 0.2s ease-out, display 0.2s allow-discrete, overlay 0.2s allow-discrete;
    background-color: rgb(0 0 0 / 0);
  }

  dialog[open] {
    opacity: 1;
    transform: scale(1);
  }

  dialog[open]::backdrop {
    background-color: rgb(0 0 0 / 0.5);
  }


  @starting-style {
    dialog[open] {
      opacity: 0;
      transform: scale(0.95);
    }
    dialog[open]::backdrop {
      background-color: rgb(0 0 0 / 0);
    }
  }
</style>

<dialog
  id="turbo-confirm-dialog"
  closedby="any"
  aria-labelledby="turbo-confirm-title"
  aria-describedby="turbo-confirm-message"
  class="m-auto w-[90%] max-w-md rounded-2xl bg-white p-6 shadow-2xl md:p-8"
>
  <header class="mb-6">
    <hgroup>
      <h3 id="turbo-confirm-title" class="text-xl font-semibold text-gray-900">
        Confirmar
      </h3>

      <p id="turbo-confirm-message" class="mt-2 text-sm leading-relaxed text-gray-500"></p>
    </hgroup>
  </header>

  <!-- Flex-col para móvil (apilado), sm:flex-row para desktop (lado a lado) -->
  <footer class="mt-8 flex flex-col justify-end gap-3 sm:flex-row">
    <button
      type="button"
      commandfor="turbo-confirm-dialog"
      command="close"
      class="btn-outline w-full sm:w-auto"
    >
      Cancel
    </button>

    <form method="dialog" class="w-full sm:w-auto">
      <button type="submit" value="confirm" class="btn-primary w-full sm:w-auto">
        Confirm
      </button>
    </form>
  </footer>
</dialog>
